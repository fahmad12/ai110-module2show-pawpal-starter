classDiagram
    %% PawPal+ — pet care planning app (Module 2 draft UML)

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task) void
        +list_tasks() list~Task~
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +priority_score() int
        +fits_in(remaining_minutes) bool
    }

    class Scheduler {
        +list~Task~ tasks
        +int available_minutes
        +build_plan() DailyPlan
        +explain() str
    }

    class DailyPlan {
        +list entries
        +list~Task~ skipped
        +to_text() str
        +total_time() int
    }

    Pet "1" --> "*" Task : has
    Scheduler --> Task : schedules
    Scheduler ..> DailyPlan : produces
    DailyPlan "1" --> "*" Task : contains
